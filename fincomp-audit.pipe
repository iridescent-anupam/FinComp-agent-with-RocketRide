    {
      "id": "question_1",
      "provider": "question",
      "name": "Question",
      "config": { "type": "question" },
      "ui": { "position": { "x": 710, "y": -190 }, "nodeType": "default", "formDataValid": true },
      "input": [ { "lane": "text", "from": "anonymize_1" } ]
    },
    {
      "id": "prompt_1",
      "provider": "prompt",
      "name": "Audit Prompt",
      "config": {
        "instructions": [
          "You are Stage 3 of 3 (Audit) in a data-privacy compliance pipeline — an independent, skeptical reviewer. You did not produce the Verdict yourself; treat it as a claim to check, not a fact.",
          "The input contains two marked sections: [VERDICT] a JSON object produced by the Verdict stage, and [RETRIEVED_REGULATIONS] the regulation entries a retrieval step matched to this case — your ONLY valid source of regulatory text, re-read from scratch here rather than trusting [VERDICT]'s paraphrase of what the regulation says.",
          "Find the entry in [RETRIEVED_REGULATIONS] matching [VERDICT]'s cited_regulation id. Re-examine independently whether that entry's summary actually supports [VERDICT]'s stated verdict — actively look for a reason it might not, rather than confirming by default.",
          "If you find a flaw, set audit_passed to false, explain the disagreement in audit_notes (under 80 words), and set final_verdict to your corrected verdict. If the verdict is sound, set audit_passed to true and still briefly explain why in audit_notes — never leave it empty. final_verdict must be exactly one of compliant, non-compliant, or needs_review.",
          "Generate a short audit_id as the literal string 'audit-' followed by 8 hex-looking characters you make up.",
          "Output ONLY a single JSON object, no prose, no markdown code fences: {\"audit_passed\": boolean, \"audit_notes\": string, \"final_verdict\": string, \"cited_regulation\": string, \"audit_id\": string}"
        ]
      },
      "ui": { "position": { "x": 950, "y": -190 }, "nodeType": "default", "formDataValid": true },
      "input": [ { "lane": "questions", "from": "question_1" } ]
    },
    {
      "id": "guardrails_input_1",
      "provider": "guardrails",
      "name": "Guardrails — input safety",
      "config": {
        "profile": "custom",
        "custom": {
          "policy_mode": "block",
          "enable_prompt_injection": true,
          "enable_content_safety": false,
          "enable_pii_detection": true,
          "enable_hallucination_check": false,
          "max_input_length": 8000,
          "max_tokens_estimate": 0,
          "expected_format": "",
          "blocked_topics": [],
          "allowed_topics": []
        }
      },
      "ui": { "position": { "x": 1190, "y": -190 }, "nodeType": "default", "formDataValid": true },
      "input": [ { "lane": "questions", "from": "prompt_1" } ]
    },
    {
