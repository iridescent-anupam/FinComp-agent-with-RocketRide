      },
      "ui": { "position": { "x": 1430, "y": -190 }, "nodeType": "default", "formDataValid": true },
      "input": [ { "lane": "questions", "from": "guardrails_input_1" } ]
    },
    {
      "id": "guardrails_output_1",
