# RocketRide Connection Settings
# These are used by the SDK to connect to the server (automatically configured when using extension)
ROCKETRIDE_URI=http://127.0.0.1:64836
ROCKETRIDE_APIKEY=dummy

# OpenAI API Key used by the LLM nodes in the compliance pipelines
ROCKETRIDE_OPENAI_KEY=your_openai_api_key_here
