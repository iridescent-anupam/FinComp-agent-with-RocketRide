    {
      "id": "question_1",
      "provider": "question",
      "name": "Question",
      "config": { "type": "question" },
      "ui": { "position": { "x": 710, "y": -190 }, "nodeType": "default", "formDataValid": true },
      "input": [ { "lane": "text", "from": "anonymize_1" } ]
    },
    {
      "id": "prompt_1",
      "provider": "prompt",
      "name": "Verdict Prompt",
      "config": {
        "instructions": [
          "You are Stage 2 of 3 (Verdict) in a data-privacy compliance pipeline. You did not perform the Triage step and will not see the Audit step — reason independently from what's given below, do not assume anything not stated.",
          "The input contains two marked sections: [TRIAGE] a JSON object produced by the Triage stage, and [RETRIEVED_REGULATIONS] the regulation entries a retrieval step matched to this case — your ONLY valid source of regulatory text. Never use outside knowledge about GDPR/CCPA beyond what's in [RETRIEVED_REGULATIONS].",
          "Find the entry in [RETRIEVED_REGULATIONS] matching the [TRIAGE] object's regulation_guess id. Reason ONLY from that entry's summary text and the facts in [TRIAGE] to a verdict: exactly one of compliant, non-compliant, or needs_review. If regulation_guess doesn't match any entry in [RETRIEVED_REGULATIONS], set verdict to needs_review and say why in reasoning.",
          "Output ONLY a single JSON object, no prose, no markdown code fences: {\"verdict\": string, \"reasoning\": string (under 100 words, cites only facts present in the matched entry's summary), \"cited_regulation\": string (the regulation id used), \"confidence\": string (low, medium, or high)}"
        ]
      },
      "ui": { "position": { "x": 950, "y": -190 }, "nodeType": "default", "formDataValid": true },
      "input": [ { "lane": "questions", "from": "question_1" } ]
    },
    {
      "id": "guardrails_input_1",
      "provider": "guardrails",
      "name": "Guardrails — input safety",
      "config": {
        "profile": "custom",
        "custom": {
          "policy_mode": "block",
          "enable_prompt_injection": true,
          "enable_content_safety": false,
          "enable_pii_detection": true,
          "enable_hallucination_check": false,
          "max_input_length": 8000,
          "max_tokens_estimate": 0,
          "expected_format": "",
          "blocked_topics": [],
          "allowed_topics": []
        }
      },
      "ui": { "position": { "x": 1190, "y": -190 }, "nodeType": "default", "formDataValid": true },
      "input": [ { "lane": "questions", "from": "prompt_1" } ]
    },
    {
